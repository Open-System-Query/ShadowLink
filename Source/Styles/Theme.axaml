<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0D141D" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#F7FAFD" />
    <SolidColorBrush x:Key="AccentBrush" Color="#009CD2" />
    <SolidColorBrush x:Key="AccentStrongBrush" Color="#0086B3" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#D9F1FA" />
    <SolidColorBrush x:Key="AccentSurfaceBrush" Color="#EAF7FC" />
    <SolidColorBrush x:Key="AccentSurfaceHoverBrush" Color="#D9F0F9" />
    <SolidColorBrush x:Key="AccentSurfacePressedBrush" Color="#C6E9F6" />
    <SolidColorBrush x:Key="AccentBorderSoftBrush" Color="#9ED6EA" />
    <SolidColorBrush x:Key="AccentSelectionBrush" Color="#C7EAF7" />
    <SolidColorBrush x:Key="BorderBrush" Color="#D6E1EA" />
    <SolidColorBrush x:Key="HeadingBrush" Color="#132131" />
    <SolidColorBrush x:Key="MutedBrush" Color="#5D6F82" />
    <SolidColorBrush x:Key="TextControlBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#F4F8FB" />
    <SolidColorBrush x:Key="TextControlForeground" Color="#132131" />
    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#132131" />
    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#132131" />
    <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="#7F93A7" />
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#D4E0E8" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#AFCAD7" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#009CD2" />
    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#DCE6ED" />
    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#7B8FA3" />
    <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#C7EAF7" />
    <LinearGradientBrush x:Key="TopShellBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#131C27" Offset="0" />
      <GradientStop Color="#0E1620" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="StageBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#FFFFFF" Offset="0" />
      <GradientStop Color="#F4F8FC" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BannerBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#152232" Offset="0" />
      <GradientStop Color="#101A26" Offset="1" />
    </LinearGradientBrush>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
    <Setter Property="FontFamily" Value="Aptos, Segoe UI, Noto Sans, sans-serif" />
    <Setter Property="Foreground" Value="{StaticResource HeadingBrush}" />
  </Style>

  <Style Selector="Border.top-shell">
    <Setter Property="Background" Value="{StaticResource TopShellBrush}" />
    <Setter Property="BorderBrush" Value="#223243" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="26" />
    <Setter Property="Padding" Value="18" />
    <Setter Property="BoxShadow" Value="0 16 36 0 #33000000" />
  </Style>

  <Style Selector="Border.stage-card">
    <Setter Property="Background" Value="{StaticResource StageBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
